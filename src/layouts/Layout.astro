---
import '../styles/global.css';

export interface Props {
  title: string;
  screenLabel?: string;
  selectionColor?: string;
}

const {
  title,
  screenLabel,
  selectionColor = 'oklch(70% 0.17 45 / 0.25)',
} = Astro.props;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,500;0,600;1,400&family=Manrope:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body style={`--selection-color:${selectionColor}`}>
  <div
    style="min-height:100vh;display:flex;flex-direction:column;font-family:'Manrope',sans-serif;color:oklch(24% 0.02 50)"
    data-screen-label={screenLabel}
  >
    <slot />
  </div>
</body>
</html>
