---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Placeholder from '../../components/Placeholder.astro';

const base = import.meta.env.BASE_URL;
---
<Layout title="Project Two — Jarrett Li" screenLabel="Project Two case study" selectionColor="oklch(54% 0.12 250 / 0.25)">
  <Nav active="two" accentColor="oklch(54% 0.12 250)" />

  <header style="padding:96px 48px 56px;max-width:920px;margin:0 auto;width:100%;box-sizing:border-box">
    <a href={base} class="hover-blue" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:oklch(48% 0.02 55);text-decoration:none;margin-bottom:28px">← Back to work</a>
    <p style="font-family:'Manrope',sans-serif;font-size:14px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:oklch(54% 0.12 250);margin:0 0 20px">Case study — coming soon</p>
    <h1 style="font-family:'Newsreader',serif;font-weight:500;font-size:48px;line-height:1.15;margin:0 0 20px">Project Two</h1>
    <p style="font-family:'Newsreader',serif;font-style:italic;font-size:21px;line-height:1.55;color:oklch(38% 0.02 55);max-width:680px;margin:0">Placeholder tagline — one-line summary of the project goes here.</p>
  </header>

  <section style="padding:0 48px 56px;max-width:920px;margin:0 auto;width:100%;box-sizing:border-box">
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px;border-top:1px solid oklch(88% 0.02 60);border-bottom:1px solid oklch(88% 0.02 60);padding:28px 0">
      <div><p style="font-size:11.5px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:oklch(48% 0.02 55);margin:0 0 6px">Role</p><p style="font-size:15px;margin:0">TBD</p></div>
      <div><p style="font-size:11.5px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:oklch(48% 0.02 55);margin:0 0 6px">Team</p><p style="font-size:15px;margin:0">TBD</p></div>
      <div><p style="font-size:11.5px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:oklch(48% 0.02 55);margin:0 0 6px">Timeline</p><p style="font-size:15px;margin:0">TBD</p></div>
      <div><p style="font-size:11.5px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:oklch(48% 0.02 55);margin:0 0 6px">Status</p><p style="font-size:15px;margin:0">TBD</p></div>
    </div>
  </section>

  <section style="padding:0 48px 64px;max-width:920px;margin:0 auto;width:100%;box-sizing:border-box">
    <div style="width:100%;aspect-ratio:16/9;border-radius:16px;overflow:hidden;border:1px solid oklch(88% 0.02 60)">
      <Placeholder caption="Project 02 hero mockup" />
    </div>
  </section>

  <section style="padding:0 48px 64px;max-width:760px;margin:0 auto;width:100%;box-sizing:border-box">
    <h2 style="font-family:'Newsreader',serif;font-weight:500;font-size:26px;margin:0 0 18px;color:oklch(54% 0.12 250)">Overview</h2>
    <p style="font-size:16.5px;line-height:1.75;color:oklch(30% 0.02 50);margin:0">Placeholder — project overview and context to be added.</p>
  </section>

  <section style="padding:0 48px 64px;max-width:760px;margin:0 auto;width:100%;box-sizing:border-box">
    <h2 style="font-family:'Newsreader',serif;font-weight:500;font-size:26px;margin:0 0 18px;color:oklch(54% 0.12 250)">Problem</h2>
    <p style="font-size:16.5px;line-height:1.75;color:oklch(30% 0.02 50);margin:0">Placeholder — describe the problem this project addressed.</p>
  </section>

  <section style="padding:0 48px 64px;max-width:760px;margin:0 auto;width:100%;box-sizing:border-box">
    <h2 style="font-family:'Newsreader',serif;font-weight:500;font-size:26px;margin:0 0 18px;color:oklch(54% 0.12 250)">Process</h2>
    <p style="font-size:16.5px;line-height:1.75;color:oklch(30% 0.02 50);margin:0">Placeholder — research methods, iterations, key decisions.</p>
  </section>

  <section style="padding:0 48px 96px;max-width:760px;margin:0 auto;width:100%;box-sizing:border-box">
    <h2 style="font-family:'Newsreader',serif;font-weight:500;font-size:26px;margin:0 0 18px;color:oklch(54% 0.12 250)">Solution</h2>
    <p style="font-size:16.5px;line-height:1.75;color:oklch(30% 0.02 50);margin:0">Placeholder — the final solution and outcomes.</p>
  </section>

  <Footer maxWidth="920px" padding="44px 48px" showCopyright={false}>
    <a href={`${base}projects/opus-clip`} style="text-decoration:none;font-size:14px;font-weight:600;color:oklch(54% 0.12 250)">← Previous project</a>
    <a href={`${base}projects/project-three`} style="text-decoration:none;font-size:14px;font-weight:600;color:oklch(54% 0.12 250)">Next project →</a>
  </Footer>
</Layout>
