---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Placeholder from '../components/Placeholder.astro';

const base = import.meta.env.BASE_URL;
---
<Layout title="Jarrett Li — UI/UX Designer">
  <Nav active="home" />

  <header style="padding:120px 48px 96px;max-width:920px;margin:0 auto;text-align:left;width:100%;box-sizing:border-box">
    <p style="font-family:'Manrope',sans-serif;font-size:14px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:oklch(54% 0.12 250);margin:0 0 20px">UI/UX Designer</p>
    <h1 style="font-family:'Newsreader',serif;font-weight:500;font-size:56px;line-height:1.12;margin:0 0 32px;color:oklch(24% 0.02 50)">Jarrett Li</h1>
    <p style="font-family:'Newsreader',serif;font-style:italic;font-size:24px;line-height:1.55;color:oklch(38% 0.02 55);max-width:680px;margin:0">I am a versatile designer dedicated to creating immersive, visually stunning worlds. I bridge the gap between storytelling and experience design to craft digital spaces that prioritize user happiness and emotional connection.</p>
  </header>

  <section style="padding:0 48px 40px;max-width:1180px;margin:0 auto;width:100%;box-sizing:border-box">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:36px;border-bottom:1px solid oklch(88% 0.02 60);padding-bottom:18px">
      <h2 style="font-family:'Newsreader',serif;font-weight:500;font-size:28px;margin:0">Selected Work</h2>
      <span style="font-size:13px;color:oklch(48% 0.02 55)">03 case studies</span>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:40px">

      <a href={`${base}projects/opus-clip`} class="card-lift" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:18px">
        <div style="width:100%;aspect-ratio:4/3;border-radius:14px;overflow:hidden;border:1px solid oklch(88% 0.02 60)">
          <Placeholder caption="Opus Clip mobile app screens" />
        </div>
        <div>
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
            <span style="width:8px;height:8px;border-radius:50%;background:oklch(70% 0.17 45)"></span>
            <span style="font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:oklch(70% 0.17 45)">UX Research · Mobile</span>
          </div>
          <h3 style="font-family:'Newsreader',serif;font-weight:500;font-size:22px;margin:0 0 8px">Opus Clip — AI Editing Experience</h3>
          <p style="font-size:14.5px;line-height:1.6;color:oklch(48% 0.02 55);margin:0">Researching and designing a mobile workflow so creators can generate AI clips anywhere, without friction.</p>
        </div>
      </a>

      <a href={`${base}projects/project-two`} class="card-lift" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:18px">
        <div style="width:100%;aspect-ratio:4/3;border-radius:14px;overflow:hidden;border:1px solid oklch(88% 0.02 60)">
          <Placeholder caption="Project 02 cover image" />
        </div>
        <div>
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
            <span style="width:8px;height:8px;border-radius:50%;background:oklch(54% 0.12 250)"></span>
            <span style="font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:oklch(54% 0.12 250)">Coming soon</span>
          </div>
          <h3 style="font-family:'Newsreader',serif;font-weight:500;font-size:22px;margin:0 0 8px">Project Two</h3>
          <p style="font-size:14.5px;line-height:1.6;color:oklch(48% 0.02 55);margin:0">Case study details in progress — check back soon.</p>
        </div>
      </a>

      <a href={`${base}projects/project-three`} class="card-lift" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:18px">
        <div style="width:100%;aspect-ratio:4/3;border-radius:14px;overflow:hidden;border:1px solid oklch(88% 0.02 60)">
          <Placeholder caption="Project 03 cover image" />
        </div>
        <div>
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
            <span style="width:8px;height:8px;border-radius:50%;background:oklch(54% 0.12 250)"></span>
            <span style="font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:oklch(54% 0.12 250)">Coming soon</span>
          </div>
          <h3 style="font-family:'Newsreader',serif;font-weight:500;font-size:22px;margin:0 0 8px">Project Three</h3>
          <p style="font-size:14.5px;line-height:1.6;color:oklch(48% 0.02 55);margin:0">Case study details in progress — check back soon.</p>
        </div>
      </a>

    </div>
  </section>

  <Footer maxWidth="1180px" padding="56px 48px 44px">
    <div style="display:flex;gap:26px;font-size:13px">
      <a href={`${base}about`} class="hover-orange" style="text-decoration:none;color:oklch(48% 0.02 55)">About</a>
      <a href="#" class="hover-orange" style="text-decoration:none;color:oklch(48% 0.02 55)">Email</a>
      <a href="#" class="hover-orange" style="text-decoration:none;color:oklch(48% 0.02 55)">LinkedIn</a>
    </div>
  </Footer>
</Layout>

<style>
  .card-lift {
    transition: transform 0.15s ease;
  }
</style>
