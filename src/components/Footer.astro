---
export interface Props {
  maxWidth?: string;
  padding?: string;
  showCopyright?: boolean;
}

const { maxWidth = '1180px', padding = '56px 48px 44px', showCopyright = true } = Astro.props;
---
<footer style={`margin-top:auto;padding:${padding};border-top:1px solid oklch(88% 0.02 60);display:flex;flex-wrap:wrap;gap:16px;align-items:center;justify-content:space-between;max-width:${maxWidth};margin-left:auto;margin-right:auto;width:100%;box-sizing:border-box`}>
  {showCopyright && <span style="font-size:13px;color:oklch(48% 0.02 55)">© 2026 Jarrett Li</span>}
  <slot />
</footer>
