---
export interface Props {
  caption: string;
}

const { caption } = Astro.props;
---
<div class="placeholder">
  <span>{caption}</span>
</div>
<style>
  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: oklch(94% 0.02 70 / 0.6);
    padding: 24px;
    box-sizing: border-box;
  }
  .placeholder span {
    font-family: 'Newsreader', serif;
    font-style: italic;
    font-size: 14px;
    line-height: 1.5;
    color: oklch(55% 0.02 55);
    text-align: center;
  }
</style>
